# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Django settings
DEBUG=True
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1

# Database — set DB=mysql to use MariaDB/MySQL
# Leave unset or set to anything else to use SQLite
DB=mysql
DB_NAME=news_db
DB_USER=news_user
DB_PASSWORD=your-db-password-here
DB_HOST=localhost
DB_PORT=3306

# Email backend (default: console)
# For production, use: django.core.mail.backends.smtp.EmailBackend
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=news@app.com

# Base URL for internal API calls
SITE_BASE_URL=http://localhost:8000
